// 1. ФУНКЦИЯ ОФОРМЛЕНИЯ ЗАКАЗА И ПЕРЕХОДА К ОПЛАТЕ
async function sendOrderAndPay(event) {
    event.preventDefault(); // Чтобы страница не перезагрузилась

    const form = event.target;
    const btn = form.querySelector('button');

    // Собираем товары из корзины (localStorage)
    const cart = JSON.parse(localStorage.getItem('cart')) || [];
    if (cart.length === 0) {
        alert("Ваша корзина пуста!");
        return;
    }

    // Считаем сумму и формируем список товаров
    let itemList = "";
    let totalSum = 0;
    cart.forEach((item, index) => {
        itemList += `${index + 1}. ${item.name} — ${item.price} руб.\n`;
        totalSum += parseFloat(item.price);
    });

    const name = form.name.value;
    const phone = form.phone.value;

    // Текст сообщения для вашего Telegram
    const message = `<b>💰 НОВЫЙ ЗАКАЗ (ОЖИДАЕТ ОПЛАТЫ)</b>\n\n` +
                    `<b>Товары:</b>\n${itemList}\n` +
                    `💰 <b>Сумма:</b> ${totalSum} руб.\n\n` +
                    `👤 <b>Клиент:</b> ${name}\n` +
                    `📞 <b>Телефон:</b> ${phone}`;

    // Блокируем кнопку на время отправки
    btn.disabled = true;
    btn.textContent = "Секунду...";

    try {
        // 2. Отправляем уведомление вам в Telegram
        const response = await fetch(`https://api.telegram.org/bot${botToken}/sendMessage`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                chat_id: myAdminId,
                parse_mode: 'html',
                text: message
            })
        });

        if (response.ok) {
            // 3. Формируем ссылку на оплату в ЮMoney
            const paymentUrl = `https://yoomoney.ru/transfer/process/success?receiver=${myYooMoney}&sum=${totalSum}&details=Заказ_BossStore_тел_${phone}`;

            // 4. ОЧИСТКА ДЛЯ ПОВТОРНОЙ ПОКУПКИ (важно!)
            form.reset(); 
            localStorage.removeItem('cart'); 
            
            // Если у вас на сайте есть функция, которая рисует корзину, вызываем её, чтобы она стала пустой
            if (typeof renderCart === 'function') renderCart();

            // 5. ПЕРЕХОД К ОПЛАТЕ
            window.location.href = paymentUrl;

        } else {
            alert("Ошибка. Проверьте, запущен ли бот @Boss_storesvzbot");
        }
    } catch (error) {
        alert("Ошибка сети. Попробуйте еще раз.");
    } finally {
        btn.disabled = false;
        btn.textContent = "Оформить заказ";
    }
}
