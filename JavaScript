// 1. Инициализация корзины
let cart = JSON.parse(localStorage.getItem('cart')) || [];

// 2. Функция добавления товара в корзину
function addToCart(name, price) {
    cart.push({ name: name, price: price });
    saveCart();
    renderCart();
    alert(name + " добавлен в корзину!");
}

// 3. Сохранение корзины
function saveCart() {
    localStorage.setItem('cart', JSON.stringify(cart));
}

// 4. Удаление товара
function removeFromCart(index) {
    cart.splice(index, 1);
    saveCart();
    renderCart();
}

// 5. Отрисовка корзины на экране
function renderCart() {
    const cartContainer = document.getElementById('cart-items');
    const totalElement = document.getElementById('cart-total');
    
    if (!cartContainer) return;

    cartContainer.innerHTML = '';
    let total = 0;

    cart.forEach((item, index) => {
        const itemDiv = document.createElement('div');
        itemDiv.className = 'cart-item';
        itemDiv.innerHTML = `
            <span>${item.name} - ${item.price} руб.</span>
            <button type="button" onclick="removeFromCart(${index})">❌</button>
        `;
        cartContainer.appendChild(itemDiv);
        total += parseFloat(item.price);
    });

    if (totalElement) {
        totalElement.textContent = total + " руб.";
    }
}

// 6. ФУНКЦИЯ ОФОРМЛЕНИЯ ЗАКАЗА И ПЕРЕХОДА К ОПЛАТЕ
async function sendOrderAndPay(event) {
    event.preventDefault(); // Останавливаем перезагрузку страницы

    const form = event.target;
    const btn = form.querySelector('button');

    // Проверяем корзину
    if (cart.length === 0) {
        alert("Ваша корзина пуста!");
        return;
    }

    // Собираем товары для сообщения
    let itemList = "";
    let totalSum = 0;
    cart.forEach((item, index) => {
        itemList += `${index + 1}. ${item.name} — ${item.price} руб.\n`;
        totalSum += parseFloat(item.price);
    });

    const name = form.name.value;
    const phone = form.phone.value;

    // Текст сообщения для вашего Telegram
    const message = `<b>💰 НОВЫЙ ЗАКАЗ (ОЖИДАЕТ ОПЛАТЫ)</b>\n\n` +
                    `<b>Товары:</b>\n${itemList}\n` +
                    `💰 <b>Сумма:</b> ${totalSum} руб.\n\n` +
                    `👤 <b>Клиент:</b> ${name}\n` +
                    `📞 <b>Телефон:</b> ${phone}`;

    // Блокируем кнопку
    btn.disabled = true;
    btn.textContent = "Создаем счет...";

    try {
        // Отправляем данные вам в Telegram
        const response = await fetch(`https://api.telegram.org/bot${botToken}/sendMessage`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                chat_id: myAdminId,
                parse_mode: 'html',
                text: message
            })
        });

        if (response.ok) {
            // Формируем ссылку на оплату в ЮMoney
            // details - это описание платежа, которое увидит клиент
            const paymentUrl = `https://yoomoney.ru/transfer/process/success?receiver=${myYooMoney}&sum=${totalSum}&details=Заказ_BossStore_${phone}`;

            alert("Заказ принят! Сейчас вы будете перенаправлены на страницу оплаты.");

            // --- ОЧИСТКА ДАННЫХ (ЧТОБЫ МОЖНО БЫЛО КУПИТЬ СНОВА) ---
            form.reset(); 
            cart = []; // Очищаем массив в коде
            localStorage.removeItem('cart'); // Очищаем память браузера
            renderCart(); // Обнуляем корзину на экране

            // ПЕРЕХОД К ОПЛАТЕ
            window.location.href = paymentUrl;

        } else {
            alert("Ошибка связи с ботом. Проверьте, нажали ли вы START в боте @Boss_storesvzbot");
        }
    } catch (error) {
        alert("Произошла ошибка сети. Проверьте интернет.");
    } finally {
        // Возвращаем кнопку в рабочее состояние (на случай, если клиент вернется назад)
        btn.disabled = false;
        btn.textContent = "Оформить заказ";
    }
}

// Запуск отрисовки при загрузке страницы
